{
  "rules": {
    "tracks": {
      ".read": true,
      "$trackId": {
        ".write": "auth != null && (
          !data.exists() ||
          data.child('artistId').val() === auth.uid ||
          data.child('artistId').val() === root.child('authUidMap').child(auth.uid).val() ||
          root.child('users').child(auth.uid).child('email').val() === 'vriskas@catniti.ru' ||
          root.child('users').child(root.child('authUidMap').child(auth.uid).val()).child('email').val() === 'vriskas@catniti.ru'
        )",
        "plays": {
          ".write": "auth != null"
        },
        "likes": {
          ".write": "auth != null"
        }
      }
    },
    "trackAudio": {
      "$trackId": {
        ".read": true,
        ".write": "auth != null && (
          !data.exists() ||
          root.child('tracks').child($trackId).child('artistId').val() === auth.uid ||
          root.child('tracks').child($trackId).child('artistId').val() === root.child('authUidMap').child(auth.uid).val() ||
          root.child('users').child(auth.uid).child('email').val() === 'vriskas@catniti.ru' ||
          root.child('users').child(root.child('authUidMap').child(auth.uid).val()).child('email').val() === 'vriskas@catniti.ru'
        )"
      }
    },
    "trackVideoData": {
      "$trackId": {
        ".read": true,
        ".write": "auth != null && (
          !data.exists() ||
          root.child('tracks').child($trackId).child('artistId').val() === auth.uid ||
          root.child('tracks').child($trackId).child('artistId').val() === root.child('authUidMap').child(auth.uid).val() ||
          root.child('users').child(auth.uid).child('email').val() === 'vriskas@catniti.ru' ||
          root.child('users').child(root.child('authUidMap').child(auth.uid).val()).child('email').val() === 'vriskas@catniti.ru'
        )"
      }
    },
    "users": {
      ".read": true,
      "$uid": {
        ".write": "auth != null && (
          $uid === auth.uid ||
          $uid === root.child('authUidMap').child(auth.uid).val() ||
          root.child('users').child(auth.uid).child('email').val() === 'vriskas@catniti.ru' ||
          root.child('users').child(root.child('authUidMap').child(auth.uid).val()).child('email').val() === 'vriskas@catniti.ru'
        )",
        "verified": {
          ".write": "auth != null && (root.child('users').child(auth.uid).child('email').val() === 'vriskas@catniti.ru' || root.child('users').child(root.child('authUidMap').child(auth.uid).val()).child('email').val() === 'vriskas@catniti.ru')"
        },
        "banned": {
          ".write": "auth != null && (root.child('users').child(auth.uid).child('email').val() === 'vriskas@catniti.ru' || root.child('users').child(root.child('authUidMap').child(auth.uid).val()).child('email').val() === 'vriskas@catniti.ru')"
        }
      }
    },
    "usernames": {
      ".read": true,
      "$username": {
        ".write": "auth != null && (!data.exists() || data.val() === auth.uid || data.val() === root.child('authUidMap').child(auth.uid).val() || root.child('users').child(auth.uid).child('email').val() === 'vriskas@catniti.ru')"
      }
    },
    "emails": {
      ".read": true,
      "$email": {
        ".write": "auth != null"
      }
    },
    "authUidMap": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && ($uid === auth.uid || data.val() === auth.uid || !data.exists())"
      }
    },
    "favorites": {
      "$uid": {
        ".read": true,
        ".write": "auth != null && ($uid === auth.uid || $uid === root.child('authUidMap').child(auth.uid).val())"
      }
    },
    "subscriptions": {
      "$uid": {
        ".read": true,
        ".write": "auth != null && ($uid === auth.uid || $uid === root.child('authUidMap').child(auth.uid).val())"
      }
    },
    "subscribers": {
      "$artistId": {
        ".read": true,
        "$uid": {
          ".write": "auth != null && ($uid === auth.uid || $uid === root.child('authUidMap').child(auth.uid).val())"
        }
      }
    },
    "playlists": {
      "$uid": {
        ".read": true,
        ".write": "auth != null && ($uid === auth.uid || $uid === root.child('authUidMap').child(auth.uid).val())"
      }
    },
    "history": {
      "$uid": {
        ".read": "auth != null && ($uid === auth.uid || $uid === root.child('authUidMap').child(auth.uid).val())",
        ".write": "auth != null && ($uid === auth.uid || $uid === root.child('authUidMap').child(auth.uid).val())"
      }
    },
    "presence": {
      "$uid": {
        ".read": true,
        ".write": "auth != null && ($uid === auth.uid || $uid === root.child('authUidMap').child(auth.uid).val())"
      }
    },
    "reports": {
      ".read": "auth != null && (root.child('users').child(auth.uid).child('email').val() === 'vriskas@catniti.ru' || root.child('users').child(root.child('authUidMap').child(auth.uid).val()).child('email').val() === 'vriskas@catniti.ru')",
      ".write": "auth != null"
    },
    "deletedTracks": {
      ".read": "auth != null && (root.child('users').child(auth.uid).child('email').val() === 'vriskas@catniti.ru' || root.child('users').child(root.child('authUidMap').child(auth.uid).val()).child('email').val() === 'vriskas@catniti.ru')",
      ".write": "auth != null"
    },
    "verificationRequests": {
      ".read": "auth != null && (root.child('users').child(auth.uid).child('email').val() === 'vriskas@catniti.ru' || root.child('users').child(root.child('authUidMap').child(auth.uid).val()).child('email').val() === 'vriskas@catniti.ru')",
      "$uid": {
        ".read": "auth != null && ($uid === auth.uid || $uid === root.child('authUidMap').child(auth.uid).val())",
        ".write": "auth != null && ($uid === auth.uid || $uid === root.child('authUidMap').child(auth.uid).val() || root.child('users').child(auth.uid).child('email').val() === 'vriskas@catniti.ru' || root.child('users').child(root.child('authUidMap').child(auth.uid).val()).child('email').val() === 'vriskas@catniti.ru')"
      }
    },
    "partySessions": {
      ".read": true,
      ".write": "auth != null"
    },
    "artistPhotos": {
      ".read": true,
      ".write": "auth != null"
    },
    "notifications": {
      "$uid": {
        ".read": "auth != null && ($uid === auth.uid || $uid === root.child('authUidMap').child(auth.uid).val())",
        ".write": "auth != null"
      }
    },
    "fxPresets": {
      "$uid": {
        ".read": "auth != null && ($uid === auth.uid || $uid === root.child('authUidMap').child(auth.uid).val())",
        ".write": "auth != null && ($uid === auth.uid || $uid === root.child('authUidMap').child(auth.uid).val())"
      }
    },
    "pinnedTracks": {
      "$uid": {
        ".read": true,
        ".write": "auth != null && ($uid === auth.uid || $uid === root.child('authUidMap').child(auth.uid).val())"
      }
    }
  }
}
